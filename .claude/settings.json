{
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block_attribution.py"
          },
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/sensitive-files/bash_guard.py"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/sensitive-files/file_guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-format/js_ts.py"
          },
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-format/data.py"
          },
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-format/markdown.py"
          },
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-format/python.py"
          },
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-scan/post_write_scan.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-scan/track_bash_writes.py"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-scan/track_bash_writes.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-scan/session_baseline.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-scan/stop_sweep.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-scan/stop_sweep.py"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/worktree/worktree_create.py"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/worktree/worktree_remove.py"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  }
}
